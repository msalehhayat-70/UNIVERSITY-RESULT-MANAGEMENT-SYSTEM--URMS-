@page "/hod/customise/{GradesheetId:int}"
@using URMS.Models.DTOs
@using URMS.Blazor.Services
@inject HODApiService HodApi
@inject NavigationManager Nav

<div style="margin-bottom:24px;display:flex;align-items:center;gap:12px;">
    <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/hod")'>← Back</button>
    <div>
        <h1 style="font-size:1.3rem;font-weight:700;color:var(--navy);">Customise Gradesheet</h1>
        <p style="color:var(--gray-400);font-size:0.85rem;margin-top:2px;">
            Edit marks directly. Changes will be forwarded to the Examiner once saved.
        </p>
    </div>
</div>

@if (_successMsg is not null) { <div class="alert alert-success">✓ @_successMsg</div> }
@if (_errorMsg   is not null) { <div class="alert alert-danger">✕ @_errorMsg</div>   }

@if (_loading)
{
    <div class="loading-center"><div class="spinner"></div><span>Loading gradesheet...</span></div>
}
else if (_gradesheet is not null)
{
    <!-- Info bar -->
    <div class="card" style="margin-bottom:16px;padding:14px 20px;">
        <div style="display:flex;gap:24px;flex-wrap:wrap;">
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Subject</span><br/><strong>@_gradesheet.SubjectName</strong></div>
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Code</span><br/><strong style="font-family:monospace">@_gradesheet.SubjectCode</strong></div>
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Type</span><br/><span class="credit-badge @(_gradesheet.SubjectType=="Theory"?"credit-theory":"credit-lab")">@_gradesheet.SubjectType</span></div>
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Credit Hours</span><br/><strong>@_gradesheet.CreditHours</strong></div>
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Teacher</span><br/><strong>@_gradesheet.TeacherName</strong></div>
            <div><span style="color:var(--gray-400);font-size:0.78rem;">Students</span><br/><strong>@_marks.Count</strong></div>
        </div>
    </div>

    <!-- Grade summary bar -->
    <div class="card" style="margin-bottom:16px;padding:14px 20px;">
        <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;">
            <div style="font-size:0.84rem;font-weight:600;color:var(--navy);">Live Summary:</div>
            <div style="font-size:0.84rem;">Avg: <strong>@_marks.Where(m=>m.MarksObtained>0).Select(m=>m.MarksObtained).DefaultIfEmpty(0).Average().ToString("F1")</strong></div>
            <div style="font-size:0.84rem;">Highest: <strong>@_marks.Max(m=>m.MarksObtained)</strong></div>
            <div style="font-size:0.84rem;">Lowest: <strong>@_marks.Min(m=>m.MarksObtained)</strong></div>
            <div style="font-size:0.84rem;color:var(--danger);">Fails: <strong>@_marks.Count(m=>m.Grade=="F")</strong></div>
        </div>
    </div>

    <!-- Editable marks table -->
    <div class="card">
        <div class="card-header">
            <h2>Edit Marks</h2>
            <div style="display:flex;gap:8px;">
                <button class="btn btn-ghost btn-sm" @onclick="ResetChanges">Reset</button>
                <button class="btn btn-gold" @onclick="SaveAndForward" disabled="@_saving">
                    @if (_saving) { <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div> }
                    Save & Forward to Examiner
                </button>
            </div>
        </div>

        <div class="alert alert-info" style="margin-bottom:16px;font-size:0.82rem;">
            Edit marks in the <strong>Marks Obtained</strong> column. Grade and Grade Points update automatically. Max marks: <strong>100</strong>.
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Reg No</th>
                        <th>Student Name</th>
                        <th>Marks Obtained</th>
                        <th>Grade</th>
                        <th>Grade Points</th>
                        <th>Changed</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var m in _marks)
                    {
                        var changed = m.MarksObtained != m.OriginalMarks;
                        <tr style="@(changed ? "background:#FFFDE7;" : "")">
                            <td style="color:var(--gray-400)">@(i++)</td>
                            <td style="font-family:monospace;font-size:0.82rem">@m.RegistrationNo</td>
                            <td style="font-weight:600">@m.StudentName</td>
                            <td>
                                <input type="number" min="0" max="100" step="0.5"
                                       value="@m.MarksObtained"
                                       @onchange="(e) => UpdateMark(m, e)"
                                       style="width:80px;padding:4px 8px;border:1px solid @(changed?"var(--gold)":"var(--gray-100)");
                                              border-radius:4px;font-size:0.88rem;font-weight:@(changed?"700":"400");
                                              text-align:center;" />
                            </td>
                            <td style="text-align:center;font-weight:700;color:@GradeColor(m.Grade)">@m.Grade</td>
                            <td style="text-align:center">@m.GradePoints.ToString("F2")</td>
                            <td style="text-align:center">
                                @if (changed)
                                {
                                    <span style="font-size:0.72rem;color:var(--warning);font-weight:600;">
                                        @m.OriginalMarks → @m.MarksObtained
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="padding-top:12px;border-top:1px solid var(--gray-100);margin-top:8px;display:flex;justify-content:flex-end;gap:8px;">
            <button class="btn btn-ghost" @onclick='() => Nav.NavigateTo("/hod")'>Cancel</button>
            <button class="btn btn-gold" @onclick="SaveAndForward" disabled="@_saving">
                @if (_saving) { <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div> }
                Save & Forward to Examiner
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int GradesheetId { get; set; }

    GradesheetReviewDto? _gradesheet;
    List<EditableMark> _marks = new();
    bool _loading = true, _saving;
    string? _successMsg, _errorMsg;

    protected override async Task OnInitializedAsync()
    {
        await LoadGradesheet();
    }

    async Task LoadGradesheet()
    {
        _loading = true;
        await Task.Delay(400);
        // Demo gradesheet — wire to real API
        _gradesheet = new GradesheetReviewDto
        {
            GradesheetId = GradesheetId,
            SubjectName  = "Operating Systems",
            SubjectCode  = "OS301",
            SubjectType  = "Theory",
            CreditHours  = 3,
            TeacherName  = "Sir Ahmed",
            Status       = "Pending"
        };

        // Demo marks
        var demo = new (string reg, string name, decimal marks)[]
        {
            ("232201070","Muhammad Saleh Hayat",78),
            ("232201086","Syed Ali Murtajiz Bukhari",65),
            ("232201093","Muhammad Muneeb",55),
            ("232201094","Zaigham Shahid Raja",48),
            ("232201095","Amna Gul",82),
            ("232201096","Mehwish Rauf",91),
            ("232201097","Nayyab Gul",88),
            ("232201098","Sohail Manzoor",42),
            ("232201099","Haider Ali",71),
            ("232201100","Muhammad Harib",67),
        };
        _marks = demo.Select(d => new EditableMark
        {
            StudentId      = 0,
            RegistrationNo = d.reg,
            StudentName    = d.name,
            MarksObtained  = d.marks,
            OriginalMarks  = d.marks,
            Grade          = CalcGrade(d.marks),
            GradePoints    = CalcGP(d.marks)
        }).ToList();

        _loading = false;
    }

    void UpdateMark(EditableMark m, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out decimal val))
        {
            val = Math.Clamp(val, 0, 100);
            m.MarksObtained = val;
            m.Grade         = CalcGrade(val);
            m.GradePoints   = CalcGP(val);
        }
    }

    void ResetChanges()
    {
        foreach (var m in _marks)
        {
            m.MarksObtained = m.OriginalMarks;
            m.Grade         = CalcGrade(m.OriginalMarks);
            m.GradePoints   = CalcGP(m.OriginalMarks);
        }
    }

    async Task SaveAndForward()
    {
        _saving = true;
        await Task.Delay(600);
        // Wire to: await HodApi.CustomiseAsync(GradesheetId, _marks)
        _saving = false;
        _successMsg = "Gradesheet customised and forwarded to Examiner successfully.";
        await Task.Delay(2000);
        Nav.NavigateTo("/hod");
    }

    static string CalcGrade(decimal m) => m switch
    {
        >= 85 => "A",  >= 80 => "A-", >= 75 => "B+",
        >= 71 => "B",  >= 68 => "B-", >= 64 => "C+",
        >= 61 => "C",  >= 58 => "C-", >= 54 => "D+",
        >= 50 => "D",  _     => "F"
    };

    static decimal CalcGP(decimal m) => m switch
    {
        >= 85 => 4.00m, >= 80 => 3.67m, >= 75 => 3.33m,
        >= 71 => 3.00m, >= 68 => 2.67m, >= 64 => 2.33m,
        >= 61 => 2.00m, >= 58 => 1.67m, >= 54 => 1.33m,
        >= 50 => 1.00m, _     => 0.00m
    };

    static string GradeColor(string g) => g switch
    {
        "A" or "A-"  => "var(--success)",
        "B+" or "B" or "B-" => "var(--navy)",
        "C+" or "C" or "C-" => "var(--warning)",
        "D+" or "D"  => "#E67E22",
        "F"          => "var(--danger)",
        _            => "var(--gray-700)"
    };

    class EditableMark
    {
        public int     StudentId      { get; set; }
        public string  RegistrationNo { get; set; } = "";
        public string  StudentName    { get; set; } = "";
        public decimal MarksObtained  { get; set; }
        public decimal OriginalMarks  { get; set; }
        public string  Grade          { get; set; } = "";
        public decimal GradePoints    { get; set; }
    }
}
